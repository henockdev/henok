# Required for production. The default dev secret is used if missing.
SESSION_PASSWORD=please_change_me_to_a_long_random_string_at_least_32_chars_long_for_security

# Optional AI assistant key. If unset, the assistant runs in retrieval-only mode
# using portfolio content. With an OpenAI key it upgrades to full generation.
OPENAI_API_KEY=

# GitHub personal access token to fetch repo stats for the dashboard.
GITHUB_TOKEN=
GITHUB_USERNAME=henokdev
